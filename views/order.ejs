<!DOCTYPE html>
<html>
<head>
    <title>My Orders - FullStack Cafe</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('partials/header') %>

<div class="container" style="padding: 40px;">
    <h2>📜 My Order History</h2>
    
    <% if (orders.length === 0) { %>
        <p>You haven't placed any orders yet. <a href="/products">Start Ordering!</a></p>
    <% } else { %>
        <% orders.forEach(order => { %>
            <div class="order-card" style="border: 1px solid #ddd; margin-bottom: 20px; padding: 20px; border-radius: 10px;">
                <div style="display: flex; justify-content: space-between;">
                    <h4>Order ID: <%= order._id %></h4>
                    <span class="status-badge"><%= order.status %></span>
                </div>
                <p>Date: <%= order.createdAt.toDateString() %></p>
                <hr>
                <ul>
                    <% order.items.forEach(item => { %>
                        <li><%= item.name %> x <%= item.quantity %> - ₹<%= item.price * item.quantity %></li>
                    <% }) %>
                </ul>
                <h4 style="text-align: right;">Total Paid: ₹<%= order.totalAmount %></h4>
            </div>
        <% }) %>
    <% } %>
</div>

<%- include('partials/footer') %>
</body>
</html>