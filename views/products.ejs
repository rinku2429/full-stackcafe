<!DOCTYPE html>
<html>
<head>
    <title>Food Menu</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800 font-sans">

<%- include('partials/header') %>

<!-- ================= TOP CONTROLS ================= -->

<div class="max-w-7xl mx-auto my-8">

    <!-- CATEGORY -->
    <div class="flex flex-wrap justify-center gap-3 px-5 mb-8">
        <a href="/products?category=all&search=<%= search %>" class="px-5 py-2.5 rounded-full border transition-colors <%= category==='all'?'bg-zinc-800 text-white border-zinc-800':'bg-white text-gray-600 border-gray-200 hover:bg-gray-100' %>">All</a>
        <a href="/products?category=junkfood&search=<%= search %>" class="px-5 py-2.5 rounded-full border transition-colors <%= category==='junkfood'?'bg-zinc-800 text-white border-zinc-800':'bg-white text-gray-600 border-gray-200 hover:bg-gray-100' %>">JunkFood</a>
        <a href="/products?category=coffee&search=<%= search %>" class="px-5 py-2.5 rounded-full border transition-colors <%= category==='coffee'?'bg-zinc-800 text-white border-zinc-800':'bg-white text-gray-600 border-gray-200 hover:bg-gray-100' %>">☕ Coffee</a>
        <a href="/products?category=drinks&search=<%= search %>" class="px-5 py-2.5 rounded-full border transition-colors <%= category==='drinks'?'bg-zinc-800 text-white border-zinc-800':'bg-white text-gray-600 border-gray-200 hover:bg-gray-100' %>">🥤 Drinks</a>
        <a href="/products?category=icecream&search=<%= search %>" class="px-5 py-2.5 rounded-full border transition-colors <%= category==='icecream'?'bg-zinc-800 text-white border-zinc-800':'bg-white text-gray-600 border-gray-200 hover:bg-gray-100' %>">🍨 Ice Cream</a>
        <a href="/products?category=dessert&search=<%= search %>" class="px-5 py-2.5 rounded-full border transition-colors <%= category==='dessert'?'bg-zinc-800 text-white border-zinc-800':'bg-white text-gray-600 border-gray-200 hover:bg-gray-100' %>">🍰 Dessert</a>
        <a href="/products?category=southindian&search=<%= search %>" class="px-5 py-2.5 rounded-full border transition-colors <%= category==='southindian'?'bg-zinc-800 text-white border-zinc-800':'bg-white text-gray-600 border-gray-200 hover:bg-gray-100' %>">🍲 South Indian</a>
    </div>

    <!-- SEARCH -->
    <form action="/products" method="GET" class="flex justify-center items-center px-5 mb-10">
        <input type="text" name="search" placeholder="Search food..." value="<%= search %>"
               class="w-full md:w-2/5 px-5 py-3.5 border-2 border-r-0 border-gray-200 rounded-l-full shadow-sm outline-none text-sm transition-colors focus:border-yellow-400 focus:ring-0">
        <input type="hidden" name="category" value="<%= category %>">
        <button type="submit"
                class="px-6 py-3.5 bg-zinc-800 text-white border-2 border-zinc-800 rounded-r-full font-semibold text-sm shadow-sm cursor-pointer transition-colors hover:bg-yellow-400 hover:border-yellow-400 hover:text-black">
            Search
        </button>
    </form>

</div>


<!-- ================= PRODUCT GRID ================= -->

<div class="max-w-7xl mx-auto px-5 pb-12 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-7">

<% if (foodItems && foodItems.length > 0) { %>

    <% foodItems.forEach(food => { %>

        <div class="bg-white rounded-2xl overflow-hidden shadow-sm transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl group flex flex-col">

            <img src="<%= food.image %>" 
                 alt="<%= food.name %>" 
                 class="w-full h-48 object-cover">

            <h3 class="mt-4 mx-4 text-lg font-bold text-gray-900"><%= food.name %></h3>

            <p class="mx-4 mt-1.5 mb-3 text-sm text-gray-500 line-clamp-2 min-h-[40px] flex-grow">
                <%= food.description 
                    ? food.description 
                    : "Delicious freshly prepared food made with quality ingredients." %>
            </p>

            <p class="mx-4 text-yellow-500 font-extrabold text-lg">₹ <%= food.price %></p>

            <button class="cart-btn w-[calc(100%-2rem)] mx-4 my-4 p-3 bg-zinc-800 text-white rounded-xl font-semibold tracking-wide cursor-pointer transition-all duration-300 hover:bg-black hover:-translate-y-0.5 shadow-sm"
                    data-name="<%= food.name %>"
                    data-price="<%= food.price %>"
                    data-image="<%= food.image %>">
                Add To Cart 🛒
            </button>

        </div>

    <% }) %>

<% } else { %>

    <div class="col-span-full text-center py-20">
        <h2 class="text-2xl font-bold text-gray-700 mb-2">No food items found</h2>
        <p class="text-gray-500">Try adjusting your category or search term.</p>
    </div>

<% } %>

</div>


<!-- ================= PAGINATION ================= -->

<div class="flex w-full justify-center gap-3 my-12 px-5">
<% for(let i = 1; i <= totalPages; i++){ %>
    <a href="/products?page=<%= i %>&category=<%= category %>&search=<%= search %>"
       class="w-11 h-11 flex items-center justify-center rounded-xl font-bold shadow-sm transition-all duration-300 <%= currentPage === i ? 'bg-zinc-900 text-white border-2 border-zinc-900' : 'bg-white text-gray-700 border-2 border-gray-200 hover:bg-gray-100 hover:-translate-y-1 hover:border-zinc-900' %>">
       <%= i %>
    </a>
<% } %>
</div>



<!-- ================= ADD TO CART SCRIPT ================= -->

<script>
document.addEventListener("DOMContentLoaded", () => {

    const buttons = document.querySelectorAll(".cart-btn");

    buttons.forEach(btn => {
        btn.addEventListener("click", () => {

            const item = {
                name: btn.dataset.name,
                price: btn.dataset.price,
                image: btn.dataset.image
            };

            fetch("/products/add-to-cart", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(item)
            })
            .then(res => res.json())
            .then(data => {

                if (data.success) {
                    alert(`✅ Added to cart! Total items: ${data.cartCount}, Total ₹${data.totalPrice}`);
                    
                    // Update the cart badge dynamically
                    const badge = document.getElementById("cart-count");
                    if (badge && data.cartCount !== undefined) {
                        badge.textContent = data.cartCount;
                    }
                } else {
                    alert("❌ Login required");
                    window.location.href = "/login";
                }

            })
            .catch(err => console.error("Error:", err));
        });
    });

});
</script>

<!-- Include your external script file to load the Push Notification function -->
<script src="/js/script.js"></script>
<%- include('partials/footer') %>

</body>
</html>
