<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add Product - Admin Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="admin-container">
        <h1 class="admin-title">Add New Product</h1>
        
        <div class="form-card">
            <!-- MUST have enctype="multipart/form-data" for file uploads -->
            <form action="/admin/add-product" method="POST" enctype="multipart/form-data">
                
                <label style="font-weight:bold; display:block; margin-bottom:5px;">Name:</label>
                <input type="text" name="name" placeholder="E.g., Cheese Burger" required>
                
                <label style="font-weight:bold; display:block; margin-bottom:5px;">Price (₹):</label>
                <input type="number" name="price" placeholder="E.g., 99" required min="0">

                <label style="font-weight:bold; display:block; margin-bottom:5px;">Category:</label>
                <select name="category" required>
                    <option value="junkfood">Junk Food</option>
                    <option value="coffee">Coffee</option>
                    <option value="drinks">Drinks</option>
                    <option value="icecream">Ice Cream</option>
                    <option value="southindian">South Indian</option>
                    <option value="snacks">Snacks</option>
                    <option value="dessert">Dessert</option>
                    <option value="meal">Meal</option>
                </select>

                <label style="font-weight:bold; display:block; margin-bottom:5px;">Description:</label>
                <textarea name="description" placeholder="A brief description of the product..."></textarea>
                
                <label style="font-weight:bold; display:block; margin-bottom:5px;">Upload Image:</label>
                <input type="file" name="image" class="file-input" accept="image/*">
                
                <button type="submit" class="add-btn">Add Product</button>
            </form>
        </div>

        <div class="product-list">
            <h2 style="margin-top: 40px; margin-bottom: 20px; color: #333;">Existing Menu Items</h2>
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="product-card">
                        <div style="display: flex; gap: 15px; align-items: center;">
                            <img src="<%= product.image %>" alt="<%= product.name %>" style="width:70px; height:70px; object-fit:cover; border-radius:8px;">
                            <div>
                                <strong style="display: block; font-size: 16px;"><%= product.name %></strong>
                                <span style="color: #666;">₹<%= product.price %> - <span style="text-transform: capitalize;"><%= product.category %></span></span>
                            </div>
                        </div>
                        
                        <form action="/admin/products/delete/<%= product._id %>" method="POST" style="margin: 0;">
                            <button type="submit" class="delete-btn" onclick="return confirm('Are you sure you want to delete this item?');">Delete</button>
                        </form>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="color: #666; font-style: italic;">No products found.</p>
            <% } %>
        </div>
        
        <div style="text-align: center; margin-top: 30px;">
            <a href="/admin/dashboard" style="color: var(--admin-red); font-weight: bold; text-decoration: none;">&larr; Back to Dashboard</a>
        </div>
    </div>
</body>
</html>