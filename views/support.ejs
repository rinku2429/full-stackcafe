<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Support - Contact Owner</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>
    <div class="support-container">
        <header class="support-header">
            <h1>Contact Support</h1>
            <p>Have a specific concern? Reach out to our team or the owner directly.</p>
        </header>

        <div class="support-grid">
            <section class="support-form">
                <h3>Send a Message</h3>
                <form action="/support/contact" method="POST">
                    <div class="form-group">
                        <label>Your Name</label>
                        <input type="text" name="name" required placeholder="Enter your name">
                    </div>
                    <div class="form-group">
                        <label>Your Email</label>
                        <input type="email" name="email" required placeholder="email@example.com">
                    </div>
                    <div class="form-group">
                        <label>Product Name</label>
                        <input type="text" name="product_name" required placeholder="Product related to your issue">
                    </div>
                    <div class="form-group">
                        <label>Message</label>
                        <textarea name="message" rows="6" required placeholder="Write your message here..."></textarea>
                    </div>
                    <button type="submit" class="btn primary">Send to Support</button>
                </form>
            </section>

            <section class="owner-details">
                <div class="owner-card">
                    <h3>Contact the Owner</h3>
                    <p>For urgent matters or direct feedback, feel free to contact the cafe owner:</p>
                    
                    <div class="contact-info">
                        <div class="info-item">
                            <strong>👤 Owner Name:</strong>
                            <span>Nitu Jangra</span>
                        </div>
                        <div class="info-item">
                            <strong>📞 Direct Line:</strong>
                            <span>+91 9876543210</span>
                        </div>
                        <div class="info-item">
                            <strong>✉️ Email:</strong>
                            <span>owner@fullstackcafe.com</span>
                        </div>
                        <div class="info-item">
                            <strong>⏰ Availability:</strong>
                            <span>Mon - Sat (10:00 AM - 6:00 PM)</span>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <%- include('partials/footer') %>

</body>
</html>