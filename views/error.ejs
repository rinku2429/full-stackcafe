<!DOCTYPE html>
<html>
<head>
    <title>Error</title>
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: #f4f4f4;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .error-box {
            background: white;
            padding: 50px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,.1);
            text-align: center;
            max-width: 400px;
        }

        h1 {
            color: #ff4d4d;
            margin-bottom: 20px;
        }

        p {
            color: #555;
            margin-bottom: 25px;
        }

        a {
            text-decoration: none;
            padding: 10px 20px;
            background: black;
            color: white;
            border-radius: 8px;
        }

        a:hover {
            background: #ffcc00;
            color: black;
        }
    </style>
</head>
<body>

    <div class="error-box">
        <h1>Oops ⚠️</h1>
        <p><%= message %></p>
        <a href="/">Go Back Home</a>
    </div>

</body>
</html>
